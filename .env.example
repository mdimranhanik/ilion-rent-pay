# ============================================================
# Required environment variables for stripe-rent-link
# ============================================================
# Copy this file to .env.local for local development.
# In production, set these in Vercel → Project Settings → Environment Variables.
# NEVER commit a file containing real keys — .gitignore already excludes .env*

# Your Stripe secret key.
# Use sk_test_... while testing, sk_live_... when going live.
# Get it from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Page shown after a successful payment.
# Use your client's "thank you" or confirmation page URL.
SUCCESS_URL=https://example.com/thank-you

# Page shown if the tenant clicks "Back" / cancels before paying.
# Typically the client's homepage or the rental listing page.
CANCEL_URL=https://example.com

# (Optional) Payment currency, ISO 4217 lowercase. Defaults to "usd".
# Examples: usd, aud, gbp, eur, cad
CURRENCY=usd
